{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/n-framework/nfw/main/schemas/nfw.schema.json",
  "title": "NFramework Workspace Configuration",
  "type": "object",
  "required": ["workspace"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "workspace": {
      "type": "object",
      "required": ["name", "template", "namespace"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["path", "template"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "template": {
            "type": "object",
            "required": ["id", "version"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
